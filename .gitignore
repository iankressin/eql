/target
/.worktrees

# Query export artifacts generated by running EQL
*.parquet

# JSON/CSV export artifacts written by eql_core's dump tests (e.g.
# execution_engine.rs's test_dump_results, test_dump_results_with_aliases_*)
# into the working directory; only removed after assertions pass, so a
# mid-test panic can leave one untracked. Scoped to the `test*` prefix those
# tests actually use, not a blanket `*.json`/`*.csv`, so real fixtures aren't
# hidden.
test*.json
test*.csv
